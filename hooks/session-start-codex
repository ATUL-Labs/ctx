#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BOOTSTRAP_FILE="$PLUGIN_ROOT/skills/using-lex/BOOTSTRAP.md"

if [ ! -f "$BOOTSTRAP_FILE" ]; then
    echo '{}'
    exit 0
fi

CONTENT="$(cat "$BOOTSTRAP_FILE")"

WRAPPED="<EXTREMELY_IMPORTANT>
You have lex - the universal coding companion.

Below is your condensed bootstrap. For the full protocol, read skills/using-lex/SKILL.md. For other skills, read skills/<skill-name>/SKILL.md:

---
$CONTENT
</EXTREMELY_IMPORTANT>"

ESCAPED="$(printf '%s' "$WRAPPED" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '%s' "$WRAPPED" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | awk '{printf "%s\\n", $0}')"

printf '{"additionalContext": %s}' "$ESCAPED"
