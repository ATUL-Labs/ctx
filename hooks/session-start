#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BOOTSTRAP_FILE="$PLUGIN_ROOT/skills/using-lex/BOOTSTRAP.md"

if [ ! -f "$BOOTSTRAP_FILE" ]; then
    echo '{}'
    exit 0
fi

CONTENT="$(cat "$BOOTSTRAP_FILE")"

STATE=""
if [ -f ".lex/status.md" ]; then
    STATE="$STATE

## CURRENT PROJECT STATE (.lex/status.md)
$(head -n 40 ".lex/status.md")"
fi
if [ -f ".lex/wip.md" ]; then
    STATE="$STATE

## INTERRUPTED WORK - RESUME THIS (.lex/wip.md)
$(head -n 150 ".lex/wip.md")"
fi

WRAPPED="<EXTREMELY_IMPORTANT>
You have lex - the universal coding companion.

Below is your condensed bootstrap. For the full protocol, read .lex/skills/using-lex/SKILL.md. For other skills, use the Skill tool or read .lex/skills/<skill-name>/SKILL.md:"

---
$CONTENT
$STATE
</EXTREMELY_IMPORTANT>"

ESCAPED="$(printf '%s' "$WRAPPED" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null \
  || printf '%s' "$WRAPPED" | node -e 'let d="";process.stdin.on("data",c=>d+=c).on("end",()=>console.log(JSON.stringify(d)))' 2>/dev/null \
  || printf '"lex bootstrap could not be JSON-escaped: python3 and node are both unavailable. Read the skill manually via the Skill tool."')"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{"additional_context": %s}' "$ESCAPED"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":%s}}' "$ESCAPED"
else
    printf '{"additionalContext": %s}' "$ESCAPED"
fi
